---
import { readFile } from 'node:fs/promises'
import path from 'node:path'
import BaseLayout from '../../layouts/BaseLayout.astro'
import App from '../../App'

const { id } = Astro.params as { id: string }

let city: {
  id: string
  name: string
  parent?: string
  coordinates?: { lat: number; lng: number }
  [key: string]: unknown
} | null = null
let notFound = false

try {
  const filePath = path.join(process.cwd(), 'data', 'city', `${id}.json`)
  const content = await readFile(filePath, 'utf-8')
  city = JSON.parse(content)
} catch {
  notFound = true
}

const cityName = city?.name ?? id.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase())
const parentGemeente = city?.parent ?? 'Nederland'
const canonical = `https://mijnmotorparkeren.nl/stad/${id}`

// Stub data: JSON exists but missing parkingRules
const isThinData = city !== null && !city.parkingRules

const title = city
  ? `Motor parkeren in ${cityName} | Parkeerregels`
  : `Stad niet gevonden | MijnMotorParkeren.nl`

const description = city
  ? `Mag de motor op de stoep in ${cityName} (gemeente ${parentGemeente})? Bekijk de actuele parkeerregels op MijnMotorParkeren.nl.`
  : `De stad ${cityName} werd niet gevonden. Bekijk andere steden op MijnMotorParkeren.nl.`

const schemaMarkup = city
  ? {
      '@context': 'https://schema.org',
      '@type': 'Place',
      name: cityName,
      description: `Motor parkeerregels voor ${cityName}`,
      url: canonical,
      address: {
        '@type': 'PostalAddress',
        addressLocality: cityName,
        addressCountry: 'NL',
      },
      containedInPlace: {
        '@type': 'Place',
        name: parentGemeente,
      },
      ...(city.coordinates && {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: city.coordinates.lat,
          longitude: city.coordinates.lng,
        },
      }),
    }
  : undefined

// Server-rendered content so crawlers get real, unique text per city — the
// React app is client:only and leaves the <body> empty otherwise. Doubles as a
// no-JS fallback.
const rules = (city?.parkingRules ?? null) as null | {
  free?: boolean | null
  paid?: { enabled?: boolean | null }
  motorcycleSpecific?: {
    allowedOnSidewalk?: boolean | null
    freeInPaidZones?: boolean | null
    notes?: string
  }
}
const moto = rules?.motorcycleSpecific
const sources = (city?.sources ?? []) as Array<{
  name?: string
  url?: string
  date?: string
  type?: string
}>
const lastUpdated = city?.lastUpdated as string | undefined
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1)
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={notFound || isThinData}
  image="https://mijnmotorparkeren.nl/android-chrome-512x512.png"
  keywords={`motor, parkeren, motor op de stoep, mijn motor parkeren, motor parkeren, ${cityName}`}
  schemaMarkup={schemaMarkup}
>
  <App client:only="react" initialCityId={id} />

  {
    city && rules && (
      <article class="mx-auto max-w-2xl px-4 py-10 text-gray-800">
        <nav class="text-sm text-gray-500" aria-label="Kruimelpad">
          <a href="/" class="underline">Home</a>
          {' › '}
          {city.parent && (
            <>
              <a href={`/gemeente/${city.parent}`} class="underline">
                Gemeente {capitalize(parentGemeente)}
              </a>
              {' › '}
            </>
          )}
          <span>{cityName}</span>
        </nav>
        <h1 class="mt-3 text-2xl font-bold text-gray-900">Motor parkeren in {cityName}</h1>
        <p class="mt-2 text-gray-600">
          {cityName} valt onder{' '}
          {city.parent ? (
            <a href={`/gemeente/${city.parent}`} class="text-blue-600 underline">
              gemeente {capitalize(parentGemeente)}
            </a>
          ) : (
            <span>gemeente {capitalize(parentGemeente)}</span>
          )}. Hieronder vind je de actuele parkeerregels voor motorrijders.
        </p>

        <h2 class="mt-8 text-lg font-semibold text-gray-900">
          Parkeerregels voor motoren in {cityName}
        </h2>
        <ul class="mt-3 space-y-2">
          {moto?.allowedOnSidewalk === true && <li>Op de stoep parkeren is toegestaan.</li>}
          {moto?.allowedOnSidewalk === false && (
            <li>Op de stoep of het trottoir parkeren is niet toegestaan.</li>
          )}
          {rules.paid?.enabled === true && <li>In deze plaats geldt betaald parkeren.</li>}
          {rules.paid?.enabled === false && <li>Er geldt hier geen betaald parkeren.</li>}
          {moto?.freeInPaidZones === true && (
            <li>Motoren parkeren gratis in betaalde parkeervakken.</li>
          )}
          {moto?.freeInPaidZones === false && (
            <li>In betaalde vakken geldt ook voor motoren het normale tarief.</li>
          )}
        </ul>

        {moto?.notes && <p class="mt-4 leading-relaxed">{moto.notes}</p>}

        {sources.length > 0 && (
          <>
            <h2 class="mt-8 text-lg font-semibold text-gray-900">Bronnen</h2>
            <ul class="mt-3 space-y-1">
              {sources.map((s) => (
                <li>
                  {s.url ? (
                    <a href={s.url} rel="nofollow noopener" class="text-blue-600 underline">
                      {s.name ?? s.url}
                    </a>
                  ) : (
                    <span>{s.name}</span>
                  )}
                  {s.date && <span class="text-gray-500"> ({s.date})</span>}
                </li>
              ))}
            </ul>
          </>
        )}

        {lastUpdated && (
          <p class="mt-8 text-sm text-gray-500">Laatst bijgewerkt: {lastUpdated}</p>
        )}
      </article>
    )
  }
</BaseLayout>
