---
import { readFile, readdir } from 'node:fs/promises'
import path from 'node:path'
import BaseLayout from '../../layouts/BaseLayout.astro'
import App from '../../App'

const { id } = Astro.params as { id: string }

let gemeente: {
  id: string
  name: string
  coordinates?: { lat: number; lng: number }
  [key: string]: unknown
} | null = null
let notFound = false

try {
  const filePath = path.join(process.cwd(), 'data', 'gemeentes', `${id}.json`)
  const content = await readFile(filePath, 'utf-8')
  const parsed = JSON.parse(content)
  if (parsed?.id && parsed.id === id) {
    gemeente = parsed
  } else {
    notFound = true
  }
} catch {
  notFound = true
}

const gemeenteName =
  gemeente?.name ?? id.replace(/-/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase())
const canonical = `https://mijnmotorparkeren.nl/gemeente/${id}`

// Stub data: JSON exists but no actual parking rules researched yet
const isThinData =
  gemeente !== null && !gemeente.lastUpdated && (gemeente.sources as unknown[])?.length === 0

const title = gemeente
  ? `Motor parkeren in ${gemeenteName} | Parkeerregels`
  : `Gemeente niet gevonden | MijnMotorParkeren.nl`

const description = gemeente
  ? `Mag de motor op de stoep in ${gemeenteName}? Bekijk de actuele parkeerregels voor ${gemeenteName} op MijnMotorParkeren.nl.`
  : `De gemeente ${gemeenteName} werd niet gevonden. Bekijk andere gemeenten op MijnMotorParkeren.nl.`

const schemaMarkup = gemeente
  ? {
      '@context': 'https://schema.org',
      '@type': 'Place',
      name: gemeenteName,
      description: `Motor parkeerregels voor gemeente ${gemeenteName}`,
      url: canonical,
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'NL',
        addressLocality: gemeenteName,
      },
      ...(gemeente.coordinates && {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: gemeente.coordinates.lat,
          longitude: gemeente.coordinates.lng,
        },
      }),
    }
  : undefined

// Server-rendered content so crawlers get real, unique text per gemeente — the
// React app is client:only and leaves the <body> empty otherwise.
const rules = (gemeente?.parkingRules ?? null) as null | {
  free?: boolean | null
  paid?: { enabled?: boolean | null }
  motorcycleSpecific?: {
    allowedOnSidewalk?: boolean | null
    freeInPaidZones?: boolean | null
    notes?: string
  }
}
const moto = rules?.motorcycleSpecific
const sources = (gemeente?.sources ?? []) as Array<{
  name?: string
  url?: string
  date?: string
  type?: string
}>
const lastUpdated = gemeente?.lastUpdated as string | undefined
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1)

// Child cities (internal links aid crawl discovery of /stad/ pages).
let childCities: Array<{ id: string; name: string }> = []
if (gemeente) {
  try {
    const cityDir = path.join(process.cwd(), 'data', 'city')
    const files = (await readdir(cityDir)).filter((f) => f.endsWith('.json') && f !== 'index.json')
    const parsed = await Promise.all(
      files.map(async (f) => {
        try {
          return JSON.parse(await readFile(path.join(cityDir, f), 'utf-8'))
        } catch {
          return null
        }
      })
    )
    childCities = parsed
      .filter((c) => c && c.parent === id && c.id && c.name)
      .map((c) => ({ id: c.id as string, name: c.name as string }))
      .sort((a, b) => a.name.localeCompare(b.name))
  } catch {
    /* no cities dir */
  }
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={notFound || isThinData}
  image="https://mijnmotorparkeren.nl/android-chrome-512x512.png"
  keywords={`motor, parkeren, motor op de stoep, mijn motor parkeren, motor parkeren, ${gemeenteName}`}
  schemaMarkup={schemaMarkup}
>
  <App client:only="react" initialGemeenteId={id} />

  {
    gemeente && (
      <article class="mx-auto max-w-2xl px-4 py-10 text-gray-800">
        <nav class="text-sm text-gray-500" aria-label="Kruimelpad">
          <a href="/" class="underline">Home</a>
          {' › '}
          <span>Gemeente {gemeenteName}</span>
        </nav>
        <h1 class="mt-3 text-2xl font-bold text-gray-900">Motor parkeren in {gemeenteName}</h1>

        {rules ? (
          <>
            <p class="mt-2 text-gray-600">
              De actuele parkeerregels voor motorrijders in gemeente {gemeenteName}.
            </p>
            <h2 class="mt-8 text-lg font-semibold text-gray-900">
              Parkeerregels voor motoren in {gemeenteName}
            </h2>
            <ul class="mt-3 space-y-2">
              {moto?.allowedOnSidewalk === true && <li>Op de stoep parkeren is toegestaan.</li>}
              {moto?.allowedOnSidewalk === false && (
                <li>Op de stoep of het trottoir parkeren is niet toegestaan.</li>
              )}
              {rules.paid?.enabled === true && <li>In deze gemeente geldt betaald parkeren.</li>}
              {rules.paid?.enabled === false && <li>Er geldt hier geen betaald parkeren.</li>}
              {moto?.freeInPaidZones === true && (
                <li>Motoren parkeren gratis in betaalde parkeervakken.</li>
              )}
              {moto?.freeInPaidZones === false && (
                <li>In betaalde vakken geldt ook voor motoren het normale tarief.</li>
              )}
            </ul>
            {moto?.notes && <p class="mt-4 leading-relaxed">{moto.notes}</p>}
          </>
        ) : (
          <p class="mt-2 text-gray-600">
            De parkeerregels voor motoren in gemeente {gemeenteName} worden nog verzameld.
          </p>
        )}

        {childCities.length > 0 && (
          <>
            <h2 class="mt-8 text-lg font-semibold text-gray-900">
              Plaatsen in gemeente {gemeenteName}
            </h2>
            <ul class="mt-3 space-y-1">
              {childCities.map((c) => (
                <li>
                  <a href={`/stad/${c.id}`} class="text-blue-600 underline">
                    Motor parkeren in {c.name}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}

        {sources.length > 0 && (
          <>
            <h2 class="mt-8 text-lg font-semibold text-gray-900">Bronnen</h2>
            <ul class="mt-3 space-y-1">
              {sources.map((s) => (
                <li>
                  {s.url ? (
                    <a href={s.url} rel="nofollow noopener" class="text-blue-600 underline">
                      {s.name ?? s.url}
                    </a>
                  ) : (
                    <span>{s.name}</span>
                  )}
                  {s.date && <span class="text-gray-500"> ({s.date})</span>}
                </li>
              ))}
            </ul>
          </>
        )}

        {lastUpdated && (
          <p class="mt-8 text-sm text-gray-500">Laatst bijgewerkt: {lastUpdated}</p>
        )}
      </article>
    )
  }
</BaseLayout>
